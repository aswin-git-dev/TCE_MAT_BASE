<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculators"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_margin="20dp"/>

        <!-- Calculator Selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/tab_sgpa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/iv_sgpa"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_slideshow_black_24dp"
                    app:tint="@color/purple_700"/>
                <TextView
                    android:id="@+id/tv_sgpa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SGPA"
                    android:textSize="12sp"
                    android:textColor="@color/purple_700"
                    android:layout_marginTop="4dp"/>
                <View
                    android:id="@+id/indicator_sgpa"
                    android:layout_width="30dp"
                    android:layout_height="3dp"
                    android:background="@color/purple_700"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_grade"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/iv_grade"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_gallery_black_24dp"
                    app:tint="#808080"/>
                <TextView
                    android:id="@+id/tv_grade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grade"
                    android:textSize="12sp"
                    android:textColor="#808080"
                    android:layout_marginTop="4dp"/>
                <View
                    android:id="@+id/indicator_grade"
                    android:layout_width="30dp"
                    android:layout_height="3dp"
                    android:background="@color/purple_700"
                    android:layout_marginTop="8dp"
                    android:visibility="invisible"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_attendance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/iv_attendance"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="#808080"/>
                <TextView
                    android:id="@+id/tv_attendance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attendance"
                    android:textSize="12sp"
                    android:textColor="#808080"
                    android:layout_marginTop="4dp"/>
                <View
                    android:id="@+id/indicator_attendance"
                    android:layout_width="30dp"
                    android:layout_height="3dp"
                    android:background="@color/purple_700"
                    android:layout_marginTop="8dp"
                    android:visibility="invisible"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_internal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:id="@+id/iv_internal"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="#808080"/>
                <TextView
                    android:id="@+id/tv_internal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Internal"
                    android:textSize="12sp"
                    android:textColor="#808080"
                    android:layout_marginTop="4dp"/>
                <View
                    android:id="@+id/indicator_internal"
                    android:layout_width="30dp"
                    android:layout_height="3dp"
                    android:background="@color/purple_700"
                    android:layout_marginTop="8dp"
                    android:visibility="invisible"/>
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/calculator_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:elevation="4dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>