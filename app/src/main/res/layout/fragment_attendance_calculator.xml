<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attendance Calculator"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#606060"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="75% attendance is mandatory to attend the exams."
            android:gravity="center"
            android:textColor="@color/error_red"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Total Periods in Semester"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_total_periods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Periods Skipped Till Now"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_skipped_periods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_calculate_attendance"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Calculate Status"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary_blue"
            app:cornerRadius="12dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_attendance_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_attendance_percentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="85%"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="@color/success_green"/>
                <TextView
                    android:id="@+id/tv_attendance_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safe to attend exams"
                    android:textSize="18sp"
                    android:layout_marginTop="8dp"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tv_remaining_skips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You can skip 5 more classes"
                    android:textSize="14sp"
                    android:layout_marginTop="16dp"
                    android:textColor="#606060"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>